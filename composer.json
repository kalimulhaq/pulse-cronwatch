{
    "name": "kalimulhaq/pulse-cronwatch",
    "description": "A Laravel Pulse card and recorder for monitoring scheduled commands (cron jobs): success/failure rate, last run, and duration trend over time.",
    "keywords": [
        "laravel",
        "laravel-pulse",
        "pulse",
        "scheduler",
        "cron",
        "scheduled-tasks",
        "monitoring",
        "kalimulhaq"
    ],
    "homepage": "https://github.com/kalimulhaq/pulse-cronwatch",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Kalim ul Haq",
            "email": "kalim.dir@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/pulse": "^1.4",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.3"
    },
    "autoload": {
        "psr-4": {
            "Kalimulhaq\\PulseCronwatch\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kalimulhaq\\PulseCronwatch\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Kalimulhaq\\PulseCronwatch\\PulseCronwatchServiceProvider"
            ]
        }
    }
}
